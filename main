//--------------------------------------------------------
// Application demonstrator: CONNECT FOUR game
//--------------------------------------------------------

#include "EDK_CM0.h"
#include "core_cm0.h"
#include "edk_driver.h"
#include "edk_api.h"
#include <stdio.h>

#define ROWS 6
#define COLS 7

#define CELL_W 12
#define CELL_H 12

#define BOARD_X 8
#define BOARD_Y 20

#define CURSOR_H 6

static int board[ROWS][COLS];
static int current_player;
static int cursor_col;
static int game_over;
static int winner;
static int quit_game;

static int r, c;

void clear_board_array(void);
void draw_cell(int row, int col, int value);
void draw_board(void);
void draw_cursor(void);
void draw_status(void);
void game_init(void);
int drop_piece(int col);
int count_dir(int row, int col, int dr, int dc);
int check_winner(int row, int col);
int check_draw(void);
void next_player(void);
void show_game_over(void);

void clear_board_array(void)
{
    for (r = 0; r < ROWS; r++) {
        for (c = 0; c < COLS; c++) {
            board[r][c] = 0;
        }
    }
}

void draw_cell(int row, int col, int value)
{
    int x1 = BOARD_X + col * CELL_W;
    int y1 = BOARD_Y + row * CELL_H;
    int x2 = x1 + CELL_W - 2;
    int y2 = y1 + CELL_H - 2;

    rectangle(x1, y1, x2, y2, BLUE);

    if (value == 0) {
        rectangle(x1 + 2, y1 + 2, x2 - 2, y2 - 2, BLACK);
    } else if (value == 1) {
        rectangle(x1 + 2, y1 + 2, x2 - 2, y2 - 2, RED);
    } else {
        rectangle(x1 + 2, y1 + 2, x2 - 2, y2 - 2, GREEN);
    }
}

void draw_cursor(void)
{
    int x1 = BOARD_X + cursor_col * CELL_W + 2;
    int x2 = x1 + CELL_W - 6;
    int y1 = BOARD_Y - CURSOR_H - 2;
    int y2 = BOARD_Y - 3;

    if (game_over) {
        rectangle(x1, y1, x2, y2, WHITE);
    } else if (current_player == 1) {
        rectangle(x1, y1, x2, y2, RED);
    } else {
        rectangle(x1, y1, x2, y2, GREEN);
    }
}

void draw_status(void)
{
    if (!game_over) {
        if (current_player == 1) {
            printf("\nP1 TURN");
            write_LED(0x01);
        } else {
            printf("\nP2 TURN");
            write_LED(0x02);
        }
    } else {
        if (winner == 1) {
            printf("\nP1 WIN  Press r to reset");
            write_LED(0x0F);
        } else if (winner == 2) {
            printf("\nP2 WIN  Press r to reset");
            write_LED(0xF0);
        } else {
            printf("\nDRAW    Press r to reset");
            write_LED(0xAA);
        }
    }
}

void draw_board(void)
{
    clear_screen();

    for (r = 0; r < ROWS; r++) {
        for (c = 0; c < COLS; c++) {
            draw_cell(r, c, board[r][c]);
        }
    }

    draw_cursor();
}

void game_init(void)
{
    clear_board_array();

    current_player = 1;
    cursor_col = 3;
    game_over = 0;
    winner = 0;
    quit_game = 0;

    clear_screen();
    draw_board();

    printf("\n\n-------- EDK Demo ---------");
    printf("\n---- Connect Four Game ----");
    printf("\nKeyboard a ..... move left");
    printf("\nKeyboard d .... move right");
    printf("\nKeyboard s .... drop piece");
    printf("\nKeyboard space  drop piece");
    printf("\nKeyboard r ..... soft reset");
    printf("\nKeyboard q ........... quit");
    printf("\n---------------------------");
    printf("\nP1 = RED, P2 = GREEN\n");

    Display_Int_Times();
    draw_status();

    timer_init(Timer_Load_Value_For_One_Sec, Timer_Prescaler, 1);
    timer_enable();

    NVIC_EnableIRQ(Timer_IRQn);
    NVIC_EnableIRQ(UART_IRQn);
}

int drop_piece(int col)
{
    int row;

    for (row = ROWS - 1; row >= 0; row--) {
        if (board[row][col] == 0) {
            board[row][col] = current_player;
            return row;
        }
    }

    return -1;
}

int count_dir(int row, int col, int dr, int dc)
{
    int count = 0;
    int player = board[row][col];
    int rr = row + dr;
    int cc = col + dc;

    while (rr >= 0 && rr < ROWS && cc >= 0 && cc < COLS &&
           board[rr][cc] == player) {
        count++;
        rr += dr;
        cc += dc;
    }

    return count;
}

int check_winner(int row, int col)
{
    if (1 + count_dir(row, col, 0, 1) + count_dir(row, col, 0, -1) >= 4)
        return 1;

    if (1 + count_dir(row, col, 1, 0) + count_dir(row, col, -1, 0) >= 4)
        return 1;

    if (1 + count_dir(row, col, 1, 1) + count_dir(row, col, -1, -1) >= 4)
        return 1;

    if (1 + count_dir(row, col, 1, -1) + count_dir(row, col, -1, 1) >= 4)
        return 1;

    return 0;
}

int check_draw(void)
{
    for (c = 0; c < COLS; c++) {
        if (board[0][c] == 0)
            return 0;
    }

    return 1;
}

void next_player(void)
{
    if (current_player == 1)
        current_player = 2;
    else
        current_player = 1;
}

void show_game_over(void)
{
    draw_board();
    draw_status();
}

void UART_ISR(void)
{
    char ch;
    int row;

    ch = UartGetc();

    if (ch == QUIT) {
        quit_game = 1;
        printf("\nQUIT");
        return;
    }

    if (ch == RESET) {
        game_init();
        return;
    }

    if (game_over) {
        return;
    }

    if (ch == LEFT) {
        if (cursor_col > 0) {
            cursor_col--;
            draw_board();
        }
        return;
    }

    if (ch == RIGHT) {
        if (cursor_col < COLS - 1) {
            cursor_col++;
            draw_board();
        }
        return;
    }

    if (ch == DOWN || ch == PAUSE) {
        row = drop_piece(cursor_col);

        if (row < 0) {
            printf("\nCOLUMN FULL");
            return;
        }

        draw_board();

        if (check_winner(row, cursor_col)) {
            game_over = 1;
            winner = current_player;
            show_game_over();
            return;
        }

        if (check_draw()) {
            game_over = 1;
            winner = 0;
            show_game_over();
            return;
        }

        next_player();
        draw_status();
        draw_board();
        return;
    }
}

void Timer_ISR(void)
{
    Display_Int_Times();
    timer_irq_clear();
}

int main(void)
{
    SoC_init();
    game_init();

    while (!quit_game) {
        __WFI();
    }

    NVIC_DisableIRQ(UART_IRQn);
    NVIC_DisableIRQ(Timer_IRQn);

    clear_screen();
    printf("\nGAME EXIT");

    while (1) {
        __WFI();
    }
}

